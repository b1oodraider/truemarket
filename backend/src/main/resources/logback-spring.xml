<?xml version="1.0" encoding="UTF-8"?>
<!--
    Логирование TrueMarket.

    Профиль local — человекочитаемый текст (удобно в IDE).
    Все остальные профили — JSON-структурированный вывод (CLAUDE.md 8.1).
    Поля JSON: timestamp, level, logger, thread, module (mdc), trace_id (mdc),
               user_id (mdc), message, stack_trace.
-->
<configuration scan="true" scanPeriod="30 seconds">

    <springProperty name="appName" source="spring.application.name" defaultValue="truemarket-backend"/>
    <springProperty name="activeProfile" source="spring.profiles.active" defaultValue="default"/>

    <!-- ===== Локально: текстовый вывод ===== -->
    <springProfile name="local">
        <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) [%thread] %cyan(%logger{40}) - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="STDOUT"/>
        </root>
    </springProfile>

    <!-- ===== Все остальные профили: JSON ===== -->
    <springProfile name="!local">
        <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                <providers>
                    <timestamp>
                        <fieldName>ts</fieldName>
                        <pattern>yyyy-MM-dd'T'HH:mm:ss.SSSXXX</pattern>
                        <timeZone>UTC</timeZone>
                    </timestamp>
                    <logLevel>
                        <fieldName>level</fieldName>
                    </logLevel>
                    <loggerName>
                        <fieldName>logger</fieldName>
                        <shortenedLoggerNameLength>40</shortenedLoggerNameLength>
                    </loggerName>
                    <threadName>
                        <fieldName>thread</fieldName>
                    </threadName>
                    <pattern>
                        <pattern>
                            {
                                "app": "${appName}",
                                "profile": "${activeProfile}",
                                "module": "%X{module:-}",
                                "trace_id": "%X{traceId:-}",
                                "span_id": "%X{spanId:-}",
                                "user_id": "%X{userId:-}",
                                "request_id": "%X{requestId:-}"
                            }
                        </pattern>
                    </pattern>
                    <message>
                        <fieldName>message</fieldName>
                    </message>
                    <stackTrace>
                        <fieldName>stack_trace</fieldName>
                        <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                            <maxDepthPerThrowable>30</maxDepthPerThrowable>
                            <maxLength>4096</maxLength>
                            <rootCauseFirst>true</rootCauseFirst>
                        </throwableConverter>
                    </stackTrace>
                </providers>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>
    </springProfile>

    <!-- Шумные логгеры -->
    <logger name="org.apache.tomcat" level="WARN"/>
    <logger name="org.apache.catalina" level="WARN"/>
    <logger name="org.hibernate.engine.internal.StatisticalLoggingSessionEventListener" level="WARN"/>
    <logger name="com.zaxxer.hikari" level="WARN"/>

</configuration>
